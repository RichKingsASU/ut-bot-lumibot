# ── ALPACA BROKER CONFIG ──────────────────────────────────────────
# Set to 'false' for LIVE trading (Requires explicit approval)
ALPACA_IS_PAPER=true
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_STREAM_URL=wss://stream.data.alpaca.markets/v2/iex
ALPACA_FEED=iex
ALPACA_OPTION_FEED=indicative

# ── SUPABASE CONFIG (Trading Log & State) ───────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── DASHBOARD CLIENT CONFIG (Vite) ──────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_DEFAULT_SYMBOL=SPY
VITE_DEFAULT_TIMEFRAME=5Min

# ── SECURITY ──────────────────────────────────────────────────────
# Used for flattening and admin endpoints
ADMIN_API_KEY=your_secure_admin_key

# ── RISK MANAGEMENT ──────────────────────────────────────────────
MAX_DAILY_LOSS=500.0
MAX_POSITION_SIZE=5
MAX_TRADES_PER_DAY=10

# ── STRATEGY PARAMETERS ──────────────────────────────────────────
SYMBOL=SPY
QUANTITY=1
ATR_PERIOD=10
ATR_MULT=1.0
RSI_PERIOD=14
STOP_PCT=0.005
EOD_FLATTEN_TIME=15:55

# ── OPTIONS CONTRACT CONFIG ─────────────────────────────────────
OPTION_EXPIRATION_MODE=0DTE
OPTION_EXPIRATION_DAYS_OUT=0
OPTION_STRIKE_MODE=ATM
OPTION_STRIKE_STEP=1.0
OPTION_MAX_DTE_FALLBACK=7
OPTIONS_SYMBOLS=SPY,IWM
OPTIONS_FEED=indicative
OPTIONS_DTE_MAX=7

# ── BACKFILL CONFIG ──────────────────────────────────────────────
SEED_SYMBOLS=SPY,IWM
