# Alpaca API Credentials
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_IS_PAPER=true

# Supabase (optional — for trade logging and UI config persistence)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Option contract configuration (defaults — override via UI or runtime_config.json)
OPTION_EXPIRATION_MODE=0DTE
OPTION_EXPIRATION_DAYS_OUT=0
OPTION_STRIKE_MODE=ATM
OPTION_STRIKE_STEP=1.0
OPTION_MAX_DTE_FALLBACK=7
