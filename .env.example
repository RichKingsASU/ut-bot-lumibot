# ============================================================
# Alpaca brokerage credentials (Python bot + Netlify ingest)
# ============================================================
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_STREAM_URL=wss://stream.data.alpaca.markets/v2/iex
ALPACA_FEED=iex
ALPACA_OPTION_FEED=indicative
ALPACA_IS_PAPER=true

# ============================================================
# Options contract configuration
# (defaults — override via UI or runtime_config.json)
# ============================================================
OPTION_EXPIRATION_MODE=0DTE
OPTION_EXPIRATION_DAYS_OUT=0
OPTION_STRIKE_MODE=ATM
OPTION_STRIKE_STEP=1.0
OPTION_MAX_DTE_FALLBACK=7
OPTIONS_SYMBOLS=SPY,IWM
OPTIONS_FEED=indicative
OPTIONS_DTE_MAX=7

# ============================================================
# Backfill / seed configuration (Netlify functions)
# ============================================================
SEED_SYMBOLS=SPY,IWM

# ============================================================
# Supabase — server-side (Python bot, Netlify functions)
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================================
# Dashboard — client-side (Vite, public)
# These are exposed to the browser. Use the ANON key only.
# ============================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_DEFAULT_SYMBOL=SPY
VITE_DEFAULT_TIMEFRAME=5Min
